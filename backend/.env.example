# ══════════════════════════════════════════════════════════════════════
#  Backend Environment Variables — Spring Boot
#  Copy this file to backend/.env and fill in your values.
#  These variables are mapped in application.properties via ${VAR_NAME}
# ══════════════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ───────────────────────────────────
DB_URL=jdbc:postgresql://<supabase-host>:5432/<database-name>
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_db_password

# ─── Firebase Admin SDK ───────────────────────────────────────────────
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─── JWT ──────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_minimum_256_bit_key_change_this_in_production

# ─── Cloudinary ───────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Server ───────────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev
